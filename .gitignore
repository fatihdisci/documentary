# Python
backend/.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Node
node_modules/
frontend/dist/
*.tsbuildinfo

# Secrets — never commit API keys
.env
.env.local
secrets.json

# Application data (projects, exports, temp, logs) lives outside the repo by
# default, but ignore it here too in case someone points EVB_DATA_DIR inside.
data/
*.log

# Render scratch
backend/tests/_output/
scratch/

# Deliverables: the text/JSON content packages are tracked, but not the
# generated images — those live in a per-animal pics/ folder and stay local.
deliverables/**/pics/
deliverables/**/*.png
deliverables/**/*.jpg
deliverables/**/*.jpeg
deliverables/**/*.webp

# macOS
.DS_Store
